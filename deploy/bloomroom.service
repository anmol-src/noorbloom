[Unit]
Description=Noor Bloom Room Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/noor-bloom-room
EnvironmentFile=/opt/noor-bloom-room/.env
ExecStart=/opt/noor-bloom-room/venv/bin/gunicorn bloomroom.wsgi:application --bind 127.0.0.1:8003 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
